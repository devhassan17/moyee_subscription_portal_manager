<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Brew Guide Views & Window Action -->
    <record id="moyee_portal_brew_guide_view_tree" model="ir.ui.view">
        <field name="name">moyee.portal.brew.guide.view.tree</field>
        <field name="model">moyee.portal.brew.guide</field>
        <field name="arch" type="xml">
            <list editable="bottom" multi_edit="1">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="sub_info"/>
                <field name="url"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <record id="moyee_portal_brew_guide_view_form" model="ir.ui.view">
        <field name="name">moyee.portal.brew.guide.view.form</field>
        <field name="model">moyee.portal.brew.guide</field>
        <field name="arch" type="xml">
            <form string="Portal Brew Guide">
                <sheet>
                    <group>
                        <field name="sequence"/>
                        <field name="is_active"/>
                    </group>
                    <group>
                        <field name="name" placeholder="e.g. V60"/>
                        <field name="sub_info" placeholder="e.g. 3 min · 1:16"/>
                        <field name="url" placeholder="e.g. /shop"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_moyee_portal_brew_guide" model="ir.actions.act_window">
        <field name="name">Portal Brew Guides</field>
        <field name="res_model">moyee.portal.brew.guide</field>
        <field name="view_mode">list,form</field>
        <field name="target">current</field>
    </record>

    <!-- FAQ Views & Window Action -->
    <record id="moyee_portal_faq_view_tree" model="ir.ui.view">
        <field name="name">moyee.portal.faq.view.tree</field>
        <field name="model">moyee.portal.faq</field>
        <field name="arch" type="xml">
            <list editable="bottom" multi_edit="1">
                <field name="sequence" widget="handle"/>
                <field name="question"/>
                <field name="answer"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <record id="moyee_portal_faq_view_form" model="ir.ui.view">
        <field name="name">moyee.portal.faq.view.form</field>
        <field name="model">moyee.portal.faq</field>
        <field name="arch" type="xml">
            <form string="Portal FAQ">
                <sheet>
                    <group>
                        <field name="sequence"/>
                        <field name="is_active"/>
                    </group>
                    <group>
                        <field name="question" placeholder="e.g. How do I change my billing address?"/>
                        <field name="answer" placeholder="e.g. Click on Update address in the billing modal..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_moyee_portal_faq" model="ir.actions.act_window">
        <field name="name">Portal FAQs</field>
        <field name="res_model">moyee.portal.faq</field>
        <field name="view_mode">list,form</field>
        <field name="target">current</field>
    </record>

    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.moyee</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="100"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Moyee Portal Settings" name="moyee_subscription_portal_manager">
                    
                    <block title="General Configuration" name="moyee_general_block">
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="company_id" string="Active Company"/>
                                    <div class="text-muted">Select the Odoo company you are currently configuring.</div>
                                    <field name="company_id" options="{'no_create': True, 'no_open': True}"/>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="moyee_enable_portal_redesign"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="moyee_enable_portal_redesign"/>
                                    <div class="text-muted">Toggle the Moyee premium account portal redesign for the selected company. If turned off, Odoo's default portal layout and styling will be restored for this company.</div>
                                </div>
                            </div>
                        </div>
                    </block>

                    <block title="Portal Styling Overrides" name="moyee_styling_block">
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="moyee_primary_color"/>
                                    <div class="text-muted">Set the primary theme color for buttons, active states, etc.</div>
                                    <field name="moyee_primary_color" widget="color"/>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="moyee_secondary_color"/>
                                    <div class="text-muted">Set the background highlight/accent color (used for banners and friend invitation card).</div>
                                    <field name="moyee_secondary_color" widget="color"/>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="moyee_font_family"/>
                                    <div class="text-muted">Set the custom Google Font family for the portal home.</div>
                                    <field name="moyee_font_family"/>
                                </div>
                            </div>
                        </div>
                    </block>

                    <block title="Portal Visibility Controls" name="moyee_visibility_block">
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="moyee_show_subscription"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="moyee_show_subscription"/>
                                    <div class="text-muted">Show active subscription details card.</div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="moyee_show_overview"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="moyee_show_overview"/>
                                    <div class="text-muted">Show quick-scroll grid navigation.</div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="moyee_show_orders"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="moyee_show_orders"/>
                                    <div class="text-muted">Show recent orders section.</div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="moyee_show_invoices"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="moyee_show_invoices"/>
                                    <div class="text-muted">Show recent invoices section.</div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="moyee_show_faq"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="moyee_show_faq"/>
                                    <div class="text-muted">Show dynamic FAQ section.</div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="moyee_show_inspire"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="moyee_show_inspire"/>
                                    <div class="text-muted">Show Ethiopian Coffee Story inspiration section.</div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="moyee_show_taf"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="moyee_show_taf"/>
                                    <div class="text-muted">Show Tell-a-Friend recommendation form.</div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="moyee_show_brew_guides"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="moyee_show_brew_guides"/>
                                    <div class="text-muted">Show dynamic Brew Guides section.</div>
                                </div>
                            </div>
                        </div>
                    </block>

                    <block title="Sidebar Widget Visibility" name="moyee_sidebar_block">
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="moyee_show_sidebar_profile"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="moyee_show_sidebar_profile"/>
                                    <div class="text-muted">Show partner profile contact details in sidebar.</div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="moyee_show_sidebar_upsell"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="moyee_show_sidebar_upsell"/>
                                    <div class="text-muted">Show subscription upsell card for non-subscribers in sidebar.</div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="moyee_show_sidebar_support"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="moyee_show_sidebar_support"/>
                                    <div class="text-muted">Show support resource link list in sidebar.</div>
                                </div>
                            </div>
                        </div>
                    </block>

                    <block title="Dynamic Content Customizations" name="moyee_content_block">
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="moyee_upsell_cta_url"/>
                                    <div class="text-muted">Destination link for "Explore Subscriptions" buttons (e.g. /shop).</div>
                                    <field name="moyee_upsell_cta_url"/>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="moyee_support_email"/>
                                    <div class="text-muted">Primary support/hello contact email.</div>
                                    <field name="moyee_support_email"/>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="moyee_brew_guides_all_url"/>
                                    <div class="text-muted">Destination link for the "ALL BREW GUIDES" button.</div>
                                    <field name="moyee_brew_guides_all_url"/>
                                </div>
                            </div>
                        </div>
                    </block>

                    <block title="Inspire Section Customizations" name="moyee_inspire_customization_block">
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="moyee_inspire_eyebrow"/>
                                    <div class="text-muted">Tagline/Eyebrow text displayed at the top of the block.</div>
                                    <field name="moyee_inspire_eyebrow"/>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="moyee_inspire_title"/>
                                    <div class="text-muted">Main headline of the inspire story.</div>
                                    <field name="moyee_inspire_title"/>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="moyee_inspire_body"/>
                                    <div class="text-muted">The body paragraph of the inspire story.</div>
                                    <field name="moyee_inspire_body" widget="text"/>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="moyee_inspire_btn1_text"/>
                                    <div class="text-muted">Text for the primary story button.</div>
                                    <field name="moyee_inspire_btn1_text"/>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="moyee_inspire_btn1_url"/>
                                    <div class="text-muted">Link/URL for the primary story button.</div>
                                    <field name="moyee_inspire_btn1_url"/>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="moyee_inspire_btn2_text"/>
                                    <div class="text-muted">Text for the secondary shop/browse button.</div>
                                    <field name="moyee_inspire_btn2_text"/>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="moyee_inspire_btn2_url"/>
                                    <div class="text-muted">Link/URL for the secondary shop/browse button.</div>
                                    <field name="moyee_inspire_btn2_url"/>
                                </div>
                            </div>
                        </div>
                    </block>

                    <block title="Portal FAQs Management" name="moyee_faq_mgmt_block">
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <span class="o_form_label">Manage FAQs</span>
                                    <div class="text-muted">Create, edit, delete and reorder FAQs displayed on the customer portal dashboard.</div>
                                    <div class="mt8">
                                        <button name="%(action_moyee_portal_faq)d" 
                                                icon="oi-arrow-right"
                                                string="Configure Portal FAQs" 
                                                type="action" 
                                                class="btn-link"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <span class="o_form_label">Manage Brew Guides</span>
                                    <div class="text-muted">Create, edit, delete and reorder Brew Guide blocks displayed on the customer portal dashboard.</div>
                                    <div class="mt8">
                                        <button name="%(action_moyee_portal_brew_guide)d" 
                                                icon="oi-arrow-right"
                                                string="Configure Brew Guides" 
                                                type="action" 
                                                class="btn-link"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </block>

                </app>
            </xpath>
        </field>
    </record>

    <!-- Settings Menu & Action -->
    <record id="action_moyee_portal_settings" model="ir.actions.act_window">
        <field name="name">Moyee Portal Customization</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'moyee_subscription_portal_manager', 'status': 1}</field>
    </record>

    <menuitem id="menu_moyee_portal_root"
              name="Moyee Portal"
              sequence="10"/>

    <menuitem id="menu_moyee_portal_settings"
              name="Configuration"
              parent="menu_moyee_portal_root"
              action="action_moyee_portal_settings"
              sequence="100"/>

    <menuitem id="menu_moyee_portal_faq"
              name="Portal FAQs"
              parent="menu_moyee_portal_root"
              action="action_moyee_portal_faq"
              sequence="20"/>

    <menuitem id="menu_moyee_portal_brew_guide"
              name="Portal Brew Guides"
              parent="menu_moyee_portal_root"
              action="action_moyee_portal_brew_guide"
              sequence="30"/>

</odoo>
