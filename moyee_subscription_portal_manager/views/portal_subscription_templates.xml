<?xml version="1.0" encoding="utf-8"?>
<!-- File: moyee_subscription_portal_manager/views/portal_subscription_templates.xml -->
<odoo>

    <!-- =========================================================
         1) Add "Manage Subscription" button on portal sale order page
         ========================================================= -->
    <template id="sale_order_portal_content_moyee_manage_link"
              inherit_id="sale.sale_order_portal_content"
              name="Moyee Subscription Manage Link">

        <!-- Try preferred table body first -->
        <xpath expr="//tbody[@id='sale_info_table']" position="inside">
            <tr t-if="sale_order and sale_order.is_subscription_order">
                <th class="ps-0 pb-0">Subscription:</th>
                <td class="w-100 pb-0 text-wrap">
                    <a t-attf-href="/my/subscriptions/{{ sale_order.id }}/moyee/manage"
                       class="btn btn-sm btn-outline-primary">
                        Manage Subscription
                    </a>
                </td>
            </tr>
        </xpath>

        <!-- Fallback if theme/build changed table id -->
        <xpath expr="//table[contains(@class,'table')][1]//tbody" position="inside">
            <tr t-if="sale_order and sale_order.is_subscription_order">
                <th class="ps-0 pb-0">Subscription:</th>
                <td class="w-100 pb-0 text-wrap">
                    <a t-attf-href="/my/subscriptions/{{ sale_order.id }}/moyee/manage"
                       class="btn btn-sm btn-outline-primary">
                        Manage Subscription
                    </a>
                </td>
            </tr>
        </xpath>

    </template>

    <!-- =========================================================
         2) Manage page template (UPDATED DESIGN)
         - Pink sections like screenshot
         - Product rows with image + input style
         - Remove SKU from product names (display_default_code=False)
         - Shipping/Invoice address as FAQ dropdown (collapse)
         ========================================================= -->
    <template id="portal_subscription_manage" name="Moyee Subscription Manager">
        <t t-call="portal.portal_layout">

            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Manage Subscription</t>
            </t>

            <div class="container o_portal_wrap my-4">

                <!-- Alerts -->
                <t t-if="moyee_error">
                    <div class="alert alert-danger" role="alert">
                        <t t-esc="moyee_error"/>
                    </div>
                </t>
                <t t-if="moyee_message">
                    <div class="alert alert-success" role="status">
                        <t t-esc="moyee_message"/>
                    </div>
                </t>

                <!-- Page header -->
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                    <div>
                        <h2 class="h4 mb-0">
                            <span>Subscription</span>
                            <span class="text-muted">-</span>
                            <span t-esc="order.name"/>
                        </h2>
                        <div class="text-muted small">
                            Customer: <span t-esc="order.partner_id.display_name"/>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <a class="btn btn-light" t-attf-href="/my/subscriptions/{{ order.id }}">
                            Back to Subscription
                        </a>
                    </div>
                </div>

                <!-- TOP ROW like screenshot: Push next date (left) + Manage subscription (right) -->
                <div class="row g-3 mb-3">

                    <!-- Push next date -->
                    <div class="col-12 col-lg-6">
                        <div class="moyee-section">
                            <div class="moyee-section-header">
                                <span>Push next date</span>
                                <span class="small opacity-75">Manage next date</span>
                            </div>

                            <div class="moyee-section-body">
                                <t t-if="not next_date_field">
                                    <div class="alert alert-warning mb-0">
                                        This system does not expose a configured next date field for subscriptions.
                                    </div>
                                </t>
                                <t t-else="">
                                    <form t-attf-action="/my/subscriptions/{{ order.id }}/push_delivery_date"
                                          method="post" class="row g-3 align-items-end">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                        <div class="col-12 col-md-8">
                                            <label class="form-label moyee-label">Next date</label>
                                            <input class="form-control moyee-input" type="date" name="next_date"
                                                   t-att-value="next_date_value and next_date_value.strftime('%Y-%m-%d') or ''"/>
                                        </div>

                                        <div class="col-12 col-md-4 d-grid">
                                            <button class="btn btn-primary" type="submit">Update</button>
                                        </div>
                                    </form>
                                </t>
                            </div>
                        </div>
                    </div>

                    <!-- Manage subscription (interval + pause/resume) -->
                    <div class="col-12 col-lg-6">
                        <div class="moyee-section">
                            <div class="moyee-section-header">
                                <span>Manage subscription</span>
                                <span class="small opacity-75">Manage subscription</span>
                            </div>

                            <div class="moyee-section-body">

                                <!-- Interval -->
                                <t t-if="not available_plans">
                                    <div class="alert alert-warning mb-3">
                                        No intervals are available for this subscription.
                                    </div>
                                </t>
                                <t t-else="">
                                    <form t-attf-action="/my/subscriptions/{{ order.id }}/change_interval"
                                          method="post" class="row g-3 align-items-end">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                        <div class="col-12 col-md-7">
                                            <label class="form-label moyee-label">Current plan</label>
                                            <select class="form-select moyee-input" name="plan_id" required="required">
                                                <t t-foreach="available_plans" t-as="pl">
                                                    <option t-att-value="pl.id"
                                                            t-att-selected="current_plan_id and current_plan_id == pl.id">
                                                        <t t-esc="pl.display_name"/>
                                                    </option>
                                                </t>
                                            </select>
                                        </div>

                                        <div class="col-12 col-md-5 d-grid">
                                            <button class="btn btn-primary" type="submit">Change plan</button>
                                        </div>
                                    </form>
                                </t>

                                <hr class="my-3"/>

                                <!-- Pause/Resume -->
                                <div class="d-flex flex-wrap gap-2 justify-content-end">
                                    <form t-attf-action="/my/subscriptions/{{ order.id }}/pause" method="post">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <button class="btn btn-warning" type="submit">Pause</button>
                                    </form>
                                    <form t-attf-action="/my/subscriptions/{{ order.id }}/resume" method="post">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <button class="btn btn-success" type="submit">Resume</button>
                                    </form>
                                </div>

                            </div>
                        </div>
                    </div>

                </div>

                <!-- PRODUCTS IN SUBSCRIPTION (UPDATED DESIGN with IMAGE + SKU removed) -->
                <div class="moyee-section mb-3">
                    <div class="moyee-section-header">
                        <span>Products in subscription</span>
                        <span class="small opacity-75">Manage products in subscription</span>
                    </div>

                    <div class="moyee-section-body">
                        <t t-if="not visible_lines">
                            <div class="text-muted">No active product lines.</div>
                        </t>

                        <t t-else="">
                            <div class="d-flex flex-column gap-3">
                                <t t-foreach="visible_lines" t-as="line">
                                    <t t-if="not line.display_type">
                                        <div class="moyee-product-row">

                                            <!-- Image -->
                                            <div class="moyee-product-img">
                                                <img t-att-src="'/web/image/product.product/%s/image_128' % line.product_id.id"
                                                     alt="Product"
                                                     class="img-fluid rounded"/>
                                            </div>

                                            <!-- Product -->
                                            <div class="flex-grow-1">
                                                <label class="form-label moyee-label">Product</label>
                                                <input class="form-control moyee-input"
                                                       type="text"
                                                       readonly="readonly"
                                                       t-att-value="line.product_id.with_context(display_default_code=False).display_name or line.name"/>
                                            </div>

                                            <!-- Qty -->
                                            <div class="moyee-qty">
                                                <label class="form-label moyee-label">Quantity</label>
                                                <input class="form-control moyee-input text-center"
                                                       type="text"
                                                       readonly="readonly"
                                                       t-att-value="line.product_uom_qty"/>
                                            </div>

                                            <!-- Remove -->
                                            <div class="moyee-actions">
                                                <label class="form-label moyee-label d-none d-md-block"><t t-raw="'&#160;'"/></label>

                                                <t t-set="lname" t-value="(line.product_id.with_context(display_default_code=False).display_name or line.name or '').lower()"/>
                                                <t t-if="'delivery' in lname">
                                                    <button class="btn btn-outline-secondary moyee-btn-remove"
                                                            type="button"
                                                            onclick="alert('You can not delete delivery product.');">
                                                        Remove
                                                    </button>
                                                </t>
                                                <t t-else="">
                                                    <form t-attf-action="/my/subscriptions/{{ order.id }}/line/{{ line.id }}/remove"
                                                          method="post" class="d-inline">
                                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                        <input type="hidden" name="reason" value="Removed by customer"/>
                                                        <button class="btn btn-outline-danger moyee-btn-remove"
                                                                type="submit"
                                                                onclick="return confirm('Remove this product from your subscription?');">
                                                            Remove
                                                        </button>
                                                    </form>
                                                </t>
                                            </div>

                                        </div>
                                    </t>
                                </t>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- ADD PRODUCTS (SKU removed in dropdown) -->
                <div class="moyee-section mb-3">
                    <div class="moyee-section-header">
                        <span>Add products</span>
                        <span class="small opacity-75">Manage products</span>
                    </div>

                    <div class="moyee-section-body">
                        <form t-attf-action="/my/subscriptions/{{ order.id }}/add_product"
                              method="post" class="row g-3 align-items-end">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                            <div class="col-12 col-lg-7">
                                <label class="form-label moyee-label">Product</label>
                                <select class="form-select moyee-input" name="product_id" required="required">
                                    <t t-foreach="available_products" t-as="p">
                                        <option t-att-value="p.id">
                                            <t t-esc="p.with_context(display_default_code=False).display_name"/>
                                        </option>
                                    </t>
                                </select>
                            </div>

                            <div class="col-12 col-lg-2">
                                <label class="form-label moyee-label">Quantity</label>
                                <input class="form-control moyee-input" name="qty" type="number" step="0.01" min="0.01" value="1"/>
                            </div>

                            <div class="col-12 col-lg-3 d-grid">
                                <button class="btn btn-primary" type="submit">Update</button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- ADDRESSES (FAQ / DROPDOWN STYLE) -->
                <div class="moyee-section mb-3">
                    <div class="moyee-section-header">
                        <span>Addresses</span>
                        <span class="small opacity-75">Manage addresses</span>
                    </div>

                    <div class="moyee-section-body">
                        <form t-attf-action="/my/subscriptions/{{ order.id }}/change_address"
                              method="post" class="row g-3">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                            <!-- Shipping dropdown -->
                            <div class="col-12">
                                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                                    <div class="fw-bold">Shipping address</div>
                                    <button class="btn btn-sm btn-light moyee-dropdown-btn"
                                            type="button"
                                            data-bs-toggle="collapse"
                                            data-bs-target="#moyeeShipAddress"
                                            aria-expanded="false"
                                            aria-controls="moyeeShipAddress">
                                        Manage shipping address ▾
                                    </button>
                                </div>
                            </div>

                            <div class="col-12">
                                <div id="moyeeShipAddress" class="collapse">
                                    <div class="row g-3 mt-1">

                                        <div class="col-12 col-lg-6">
                                            <label class="form-label moyee-label">Name</label>
                                            <input class="form-control moyee-input" name="ship_name" type="text"
                                                   t-att-value="(order.partner_shipping_id and order.partner_shipping_id.name) or ''"/>
                                        </div>
                                        <div class="col-12 col-lg-6">
                                            <label class="form-label moyee-label">Phone</label>
                                            <input class="form-control moyee-input" name="ship_phone" type="text"
                                                   t-att-value="(order.partner_shipping_id and order.partner_shipping_id.phone) or ''"/>
                                        </div>

                                        <div class="col-12">
                                            <label class="form-label moyee-label">Street</label>
                                            <input class="form-control moyee-input" name="ship_street" type="text"
                                                   t-att-value="(order.partner_shipping_id and order.partner_shipping_id.street) or ''"/>
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label moyee-label">Street 2</label>
                                            <input class="form-control moyee-input" name="ship_street2" type="text"
                                                   t-att-value="(order.partner_shipping_id and order.partner_shipping_id.street2) or ''"/>
                                        </div>

                                        <div class="col-12 col-lg-4">
                                            <label class="form-label moyee-label">City</label>
                                            <input class="form-control moyee-input" name="ship_city" type="text"
                                                   t-att-value="(order.partner_shipping_id and order.partner_shipping_id.city) or ''"/>
                                        </div>
                                        <div class="col-12 col-lg-4">
                                            <label class="form-label moyee-label">ZIP</label>
                                            <input class="form-control moyee-input" name="ship_zip" type="text"
                                                   t-att-value="(order.partner_shipping_id and order.partner_shipping_id.zip) or ''"/>
                                        </div>
                                        <div class="col-12 col-lg-4">
                                            <label class="form-label moyee-label">Country</label>
                                            <select class="form-select moyee-input" name="ship_country_id">
                                                <option value="">--</option>
                                                <t t-foreach="countries" t-as="c">
                                                    <option t-att-value="c.id"
                                                            t-att-selected="order.partner_shipping_id and order.partner_shipping_id.country_id and order.partner_shipping_id.country_id.id == c.id">
                                                        <t t-esc="c.name"/>
                                                    </option>
                                                </t>
                                            </select>
                                        </div>

                                    </div>
                                </div>
                            </div>

                            <hr class="my-2"/>

                            <!-- Invoice dropdown -->
                            <div class="col-12">
                                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                                    <div class="fw-bold">Invoice address</div>
                                    <button class="btn btn-sm btn-light moyee-dropdown-btn"
                                            type="button"
                                            data-bs-toggle="collapse"
                                            data-bs-target="#moyeeInvAddress"
                                            aria-expanded="false"
                                            aria-controls="moyeeInvAddress">
                                        Manage invoice address ▾
                                    </button>
                                </div>
                            </div>

                            <div class="col-12">
                                <div id="moyeeInvAddress" class="collapse">
                                    <div class="row g-3 mt-1">

                                        <div class="col-12 col-lg-6">
                                            <label class="form-label moyee-label">Name</label>
                                            <input class="form-control moyee-input" name="inv_name" type="text"
                                                   t-att-value="(order.partner_invoice_id and order.partner_invoice_id.name) or ''"/>
                                        </div>
                                        <div class="col-12 col-lg-6">
                                            <label class="form-label moyee-label">Phone</label>
                                            <input class="form-control moyee-input" name="inv_phone" type="text"
                                                   t-att-value="(order.partner_invoice_id and order.partner_invoice_id.phone) or ''"/>
                                        </div>

                                        <div class="col-12">
                                            <label class="form-label moyee-label">Street</label>
                                            <input class="form-control moyee-input" name="inv_street" type="text"
                                                   t-att-value="(order.partner_invoice_id and order.partner_invoice_id.street) or ''"/>
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label moyee-label">Street 2</label>
                                            <input class="form-control moyee-input" name="inv_street2" type="text"
                                                   t-att-value="(order.partner_invoice_id and order.partner_invoice_id.street2) or ''"/>
                                        </div>

                                        <div class="col-12 col-lg-4">
                                            <label class="form-label moyee-label">City</label>
                                            <input class="form-control moyee-input" name="inv_city" type="text"
                                                   t-att-value="(order.partner_invoice_id and order.partner_invoice_id.city) or ''"/>
                                        </div>
                                        <div class="col-12 col-lg-4">
                                            <label class="form-label moyee-label">ZIP</label>
                                            <input class="form-control moyee-input" name="inv_zip" type="text"
                                                   t-att-value="(order.partner_invoice_id and order.partner_invoice_id.zip) or ''"/>
                                        </div>
                                        <div class="col-12 col-lg-4">
                                            <label class="form-label moyee-label">Country</label>
                                            <select class="form-select moyee-input" name="inv_country_id">
                                                <option value="">--</option>
                                                <t t-foreach="countries" t-as="c">
                                                    <option t-att-value="c.id"
                                                            t-att-selected="order.partner_invoice_id and order.partner_invoice_id.country_id and order.partner_invoice_id.country_id.id == c.id">
                                                        <t t-esc="c.name"/>
                                                    </option>
                                                </t>
                                            </select>
                                        </div>

                                    </div>
                                </div>
                            </div>

                            <div class="col-12 d-flex justify-content-end mt-2">
                                <button class="btn btn-primary" type="submit">Update</button>
                            </div>

                        </form>
                    </div>
                </div>

                <!-- Info -->
                <div class="alert alert-info mt-4 mb-0">
                    Removed products are soft-deleted (quantity set to 0 and flagged) and excluded from future recurring invoices.
                </div>

            </div>
        </t>
    </template>

</odoo>